{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["acls"],
  "additionalProperties": false,
  "properties": {
    "acls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "entries"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "type": {
            "type": "string",
            "enum": ["standard", "extended"]
          },
          "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["sequence", "action", "protocol"],
              "additionalProperties": false,
              "properties": {
                "sequence": {
                  "type": "integer",
                  "minimum": 1
                },
                "action": {
                  "type": "string",
                  "enum": ["permit", "deny"]
                },
                "protocol": {
                  "type": "string",
                  "enum": ["ip", "tcp", "udp", "icmp"]
                },
                "source": {
                  "type": "string"
                },
                "destination": {
                  "type": "string"
                },
                "dst_port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              }
            }
          }
        }
      }
    }
  }
}
