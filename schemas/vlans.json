{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["vlans"],
  "additionalProperties": false,
  "properties": {
    "vlans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "ip_range"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4094
          },
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "ip_range": {
            "type": "string"
          }
        }
      }
    }
  }
}
